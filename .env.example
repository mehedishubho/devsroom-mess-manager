APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production checklist:
# - Set APP_ENV=production and APP_DEBUG=false before deploy.
# - Generate APP_KEY with `php artisan key:generate --force`.
# - Serve over HTTPS and set APP_URL to the public HTTPS origin.

# D-21: Asia/Dhaka everywhere. config/app.php:68 defaults to UTC — overridden here.
APP_TIMEZONE=Asia/Dhaka

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# D-18: MySQL only (no sqlite in dev/prod per PROJECT.md).
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=devsroom_mess_management
DB_USERNAME=root
DB_PASSWORD=

# ----- Phase 6: Backup/restore wiring -----
# scratch DB the periodic restore-test job loads + wipes (DEPLOYMENT.md §11.3).
# RestoreTestService loads the latest backup's dump here + asserts per-table COUNT(*) parity.
DB_RESTORE_TEST_DATABASE=devsroom_mess_restore_test
# mysqldump binary DIRECTORY (not the executable). Prod Linux: leave unset or /usr/bin.
# Dev Windows: e.g. "C:\Program Files\MySQL\MySQL Server 8.0\bin" (no trailing slash).
# Spatie v10 is NOT Windows-compatible — see DEPLOYMENT.md §11.9 (Pitfall 2).
DUMP_BINARY_PATH=/usr/bin

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Production should run a persistent queue worker and scheduler:
# php artisan queue:work --tries=1
# * * * * * php /path/to/artisan schedule:run

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Production mail should use a real SMTP/API mailer so invites, password
# resets, and operational notices leave the server.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ----- Phase 6: Backup destination (DigitalOcean Spaces, S3-compatible) -----
# Provision a bucket + access keys in the DO control panel; see DEPLOYMENT.md §11.6.
# Region MUST match the endpoint subdomain (nyc3 + https://nyc3.digitaloceanspaces.com).
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=devsroom-mess-backups
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_USE_PATH_STYLE_ENDPOINT=false
# The filesystem disk (declared in config/filesystems.php) that backup:run writes to.
BACKUP_DISK=backups
# Size cap in MB; backup:monitor flags if exceeded (DEPLOYMENT.md §11.9).
BACKUP_MAX_MB=5000
# Where spatie sends failure emails. Requires MAIL_MAILER=smtp (DEPLOYMENT.md §11.7).
# Empty falls back to MAIL_FROM_ADDRESS via the runtime closure in config/backup.php.
BACKUP_NOTIFICATION_EMAIL=
# Optional AES-256 zip encryption (belt-and-suspenders over DO Spaces server-side encryption).
# Empty = no client-side encryption.
BACKUP_ARCHIVE_PASSWORD=

VITE_APP_NAME="${APP_NAME}"

TYRO_DASHBOARD_DISABLE_EXAMPLES=true
TYRO_DASHBOARD_ADMIN_BAR_ENABLED=false
TYRO_LOGIN_REDIRECT_AFTER_LOGIN=/post-login
TYRO_LOGIN_REQUIRE_EMAIL_VERIFICATION=false

# Phase 5 perf tooling — dev-only, NEVER enable in production.
TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false
